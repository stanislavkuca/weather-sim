<Window x:Class="WeatherSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeatherSim"
        mc:Ignorable="d"
        Title="" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Weather Simulator" FontWeight="Bold"
               FontSize="25" Margin="18 20 20 0"/>
        
        <!-- Control Panel -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Number of Simulated Days -->
            <TextBlock Grid.Column="0" Text="Number of days:" 
                       VerticalAlignment="Center" FontSize="18"/>
            
            <TextBox Grid.Column="2" Width="50" TextWrapping="NoWrap"
                     x:Name="NumDaysTextBox"/>

            <!-- Season Picker -->
            <TextBlock Grid.Column="4" Text="Season:" 
                       VerticalAlignment="Center" FontSize="18"/>
            
            <ComboBox Grid.Column="6" Width="80">
                <ComboBoxItem>Spring</ComboBoxItem>
                <ComboBoxItem>Summer</ComboBoxItem>
                <ComboBoxItem>Fall</ComboBoxItem>
                <ComboBoxItem>Winter</ComboBoxItem>
            </ComboBox>

            <!-- Temperature Unit Picker -->
            <TextBlock Grid.Column="8" Text="Temp unit:" 
                       VerticalAlignment="Center" FontSize="18"/>
            
            <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton VerticalContentAlignment="Center" FontSize="18" 
                             GroupName="Temp" Margin="0 0 15 0">°C</RadioButton>
                <RadioButton VerticalContentAlignment="Center" 
                             FontSize="18" GroupName="Temp">°F</RadioButton>
            </StackPanel>

            <Button Grid.Column="12" Click="SimulateButton" Content="Simulate"/>
        </Grid>

        <!-- Weather Item Card -->
        <Grid Grid.Row="2" Margin="20" HorizontalAlignment="Left">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl Name="weatherItemCollection">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ItemCardStyle}">
                                <StackPanel HorizontalAlignment="Center" Margin="10">
                                    <TextBlock Grid.Row="0" Text="{Binding DisplayDate}" Style="{StaticResource ItemTextBlockStyle}"/>
                                    <Image Grid.Row="1" Source="{Binding ImagePath}" Style="{StaticResource WeatherIconStyle}" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Temperature}" Style="{StaticResource ItemTextBlockStyle}"/>
                                    <TextBlock Grid.Row="3" Text="{Binding Weather}" Style="{StaticResource ItemTextBlockStyle}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
