<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\Icons\weather_cloudy.png" />
    <None Remove="Assets\Icons\weather_snowy.png" />
    <None Remove="Assets\Icons\weather_storm.png" />
    <None Remove="Assets\Icons\weather_sunny.png" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\Icons\weather_cloudy.png" />
    <Resource Include="Assets\Icons\weather_fog.png" />
    <Resource Include="Assets\Icons\weather_rainy.png" />
    <Resource Include="Assets\Icons\weather_snowy.png" />
    <Resource Include="Assets\Icons\weather_storm.png" />
    <Resource Include="Assets\Icons\weather_sunny.png" />
  </ItemGroup>

</Project>
